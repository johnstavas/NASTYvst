void {{ PROJECT_NAME }}AudioProcessor::prepareToPlay(double sr, int blockSize) {
    graph_.prepare(sr, blockSize);
    setLatencySamples(graph_.getLatency());
    // Allocate scratch for dry copy used by the bypass crossfade. Sized
    // to max channel count + block size known at prepare time.
    dryCopy_.setSize(juce::jmax(2, getTotalNumInputChannels()), blockSize, false, true, true);
    // 5 ms crossfade — fast enough to feel instant, slow enough to be click-free.
    const double rampSamples = juce::jmax(1.0, sr * 0.005);
    bypassFadeStep_ = 1.0 / rampSamples;
    bypassFade_ = bypass_ != nullptr && bypass_->get() ? 0.0 : 1.0;
}

