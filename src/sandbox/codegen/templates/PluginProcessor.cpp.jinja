void {{ PROJECT_NAME }}AudioProcessor::processBlock(juce::AudioBuffer<float>& buffer, juce::MidiBuffer&) {
    juce::ScopedNoDenormals noDenormals;
    const int N        = buffer.getNumSamples();
    const int numIn    = getTotalNumInputChannels();
    const int numOut   = getTotalNumOutputChannels();

    // Clear any output channels we don't write into.
    for (int ch = numIn; ch < numOut; ++ch)
        buffer.clear(ch, 0, N);

    // Input metering (peak, pre-graph).
    if (numIn >= 1) levelInL_.store(peakAbs(buffer.getReadPointer(0), N));
    if (numIn >= 2) levelInR_.store(peakAbs(buffer.getReadPointer(1), N));

    // Push current APVTS values into graph (block-rate).
{% for p in apvtsParams %}
    graph_.setParam("{{ p.nodeId }}", "{{ p.opParamId }}", apvts.getRawParameterValue("{{ p.paramId }}")->load());
{% endfor %}

    // BYPASS CROSSFADE.  Always run graph (keeps state current — no
    // wake-up transient when bypass toggles back off).  Then crossfade
    // between dry copy and processed output over ~5 ms whenever bypass
    // state is in transition.  Eliminates bypass-toggle clicks AND the
    // "first block back is wrong" issue caused by stale comp state.
    const double targetFade = (bypass_ != nullptr && bypass_->get()) ? 0.0 : 1.0;

    // Snapshot the dry input before graph_.process clobbers buffer in place.
    const int chCopy = juce::jmin(numIn, dryCopy_.getNumChannels());
    for (int ch = 0; ch < chCopy; ++ch)
        std::memcpy(dryCopy_.getWritePointer(ch), buffer.getReadPointer(ch), sizeof(float) * (size_t)N);

    graph_.process(buffer);

    // Per-sample crossfade between dryCopy_ and the processed buffer.
    // Fade advances once per sample, applied to all channels in sync.
    double fade = bypassFade_;
    const double step = bypassFadeStep_;
    for (int i = 0; i < N; ++i) {
        if (fade < targetFade) { fade += step; if (fade > targetFade) fade = targetFade; }
        else if (fade > targetFade) { fade -= step; if (fade < targetFade) fade = targetFade; }
        const float fwet = static_cast<float>(fade);
        const float fdry = static_cast<float>(1.0 - fade);
        for (int ch = 0; ch < numOut; ++ch) {
            float* wr = buffer.getWritePointer(ch);
            const float dry = (ch < chCopy) ? dryCopy_.getReadPointer(ch)[i] : 0.0f;
            wr[i] = fwet * wr[i] + fdry * dry;
        }
    }
    bypassFade_ = fade;

    if (numOut >= 1) levelOutL_.store(peakAbs(buffer.getReadPointer(0), N));
    if (numOut >= 2) levelOutR_.store(peakAbs(buffer.getReadPointer(1), N));
}

void {{ PROJECT_NAME }}AudioProcessor::processBlockBypassed(juce::AudioBuffer<float>& buffer, juce::MidiBuffer&) {
    const int N      = buffer.getNumSamples();
    const int numOut = getTotalNumOutputChannels();
    if (numOut >= 1) levelInL_.store(peakAbs(buffer.getReadPointer(0), N));
    if (numOut >= 2) levelInR_.store(peakAbs(buffer.getReadPointer(1), N));
    if (numOut >= 1) levelOutL_.store(peakAbs(buffer.getReadPointer(0), N));
    if (numOut >= 2) levelOutR_.store(peakAbs(buffer.getReadPointer(1), N));
}

