// {{ PROJECT_NAME }} editor — knob/slider/peak-meter/bypass per buildout § 4.4.
#pragma once
#include <juce_audio_processors/juce_audio_processors.h>
#include "PluginProcessor.h"

// Meter source: which atomics to read each frame.
enum class MeterSource { Input, Output };

class PeakMeterStrip : public juce::Component, private juce::Timer {
public:
    PeakMeterStrip({{ PROJECT_NAME }}AudioProcessor& p, MeterSource src, juce::String label)
        : proc_(p), source_(src), label_(std::move(label)) { startTimerHz(30); }
    void paint(juce::Graphics& g) override;
private:
    void timerCallback() override { repaint(); }
    {{ PROJECT_NAME }}AudioProcessor& proc_;
    MeterSource source_;
    juce::String label_;
    float holdL_ = 0.0f, holdR_ = 0.0f;
    int   holdCountL_ = 0, holdCountR_ = 0;
};

class {{ PROJECT_NAME }}Editor : public juce::AudioProcessorEditor {
public:
    explicit {{ PROJECT_NAME }}Editor({{ PROJECT_NAME }}AudioProcessor&);
    ~{{ PROJECT_NAME }}Editor() override = default;
    void paint(juce::Graphics&) override;
    void resized() override;

private:
    {{ PROJECT_NAME }}AudioProcessor& proc_;

    juce::TextButton bypassBtn_ { "Bypass" };
    std::unique_ptr<juce::AudioProcessorValueTreeState::ButtonAttachment> bypassAttach_;

{% if presetsMode %}
    // Preset buttons (radio-grouped). Clicking one sets every APVTS param to
    // the preset's vetted normalized value, then visually highlights itself.
{% for preset in presets %}
    juce::TextButton {{ preset.id }}Btn_ { "{{ preset.label }}" };
{% endfor %}
    // User knobs — whitelisted params that stay adjustable alongside presets.
{% for uk in userKnobs %}
    juce::Slider {{ uk.paramId }}_slider_;
    juce::Label  {{ uk.paramId }}_label_;
    std::unique_ptr<juce::AudioProcessorValueTreeState::SliderAttachment> {{ uk.paramId }}_attach_;
{% endfor %}
{% else %}
{% for p in apvtsParams %}
    juce::Slider {{ p.paramId }}_slider_;
    juce::Label  {{ p.paramId }}_label_;
    std::unique_ptr<juce::AudioProcessorValueTreeState::SliderAttachment> {{ p.paramId }}_attach_;
{% endfor %}
{% endif %}

    PeakMeterStrip meterIn_  { proc_, MeterSource::Input,  "IN"  };
    PeakMeterStrip meterOut_ { proc_, MeterSource::Output, "OUT" };

    JUCE_DECLARE_NON_COPYABLE_WITH_LEAK_DETECTOR({{ PROJECT_NAME }}Editor)
};
