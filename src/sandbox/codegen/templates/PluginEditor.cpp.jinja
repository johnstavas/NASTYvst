void {{ PROJECT_NAME }}Editor::resized() {
    auto area = getLocalBounds();

    // Top bar: title strip (44 px) leaves prominent bypass button at top-right
    // sized 120 × 32 — easily clickable, clearly labeled.
    auto top  = area.removeFromTop(44);
    bypassBtn_.setBounds(top.removeFromRight(120).reduced(6, 6));

    // Right side: dual IN / OUT meter strips, 56 px each + 8 px gap = 120 px.
    auto meterArea = area.removeFromRight(128).reduced(4, 8);
    meterIn_.setBounds(meterArea.removeFromLeft(56));
    meterArea.removeFromLeft(8);
    meterOut_.setBounds(meterArea.removeFromLeft(56));

{% if presetsMode %}
    // Reserve bottom strip for user knobs (TRIM etc.) if any.
    const int userKnobCount = {{ userKnobs|length }};
    if (userKnobCount > 0) {
        auto knobStrip = area.removeFromBottom(80).reduced(16, 4);
        const int slotW = knobStrip.getWidth() / userKnobCount;
        int xk = knobStrip.getX();
{% for uk in userKnobs %}
        {
            juce::Rectangle<int> slot(xk, knobStrip.getY(), slotW, knobStrip.getHeight());
            {{ uk.paramId }}_label_.setBounds(slot.removeFromTop(16));
            {{ uk.paramId }}_slider_.setBounds(slot.reduced(6));
            xk += slotW;
        }
{% endfor %}
    }
    // Preset buttons fill the remaining main area.
    auto btnRow = area.reduced(16, 24);
    const int btnCount = {{ presets|length }};
    if (btnCount > 0) {
        const int slotW = btnRow.getWidth() / btnCount;
        int x = btnRow.getX();
{% for preset in presets %}
        {{ preset.id }}Btn_.setBounds(juce::Rectangle<int>(x, btnRow.getY(), slotW, btnRow.getHeight()).reduced(6));
        x += slotW;
{% endfor %}
    }
{% else %}
    auto knobRow = area.reduced(8);
    const int knobCount = {{ apvtsParams|length }};
    if (knobCount > 0) {
        const int slotW = knobRow.getWidth() / knobCount;
        int x = knobRow.getX();
{% for p in apvtsParams %}
        {
            juce::Rectangle<int> slot(x, knobRow.getY(), slotW, knobRow.getHeight());
            {{ p.paramId }}_label_.setBounds(slot.removeFromTop(18));
            {{ p.paramId }}_slider_.setBounds(slot.reduced(6));
            x += slotW;
        }
{% endfor %}
    }
{% endif %}
}
