// op_envelope.cpp — Stage-3b C++ sidecar for the `envelope` op.
// Contract: memory/codegen_design.md § 4. Mirrors op_envelope.worklet.js
// bit-for-bit. Asymmetric AR follower with Watte denormal bias.
//
// Ported 2026-04-27 from op_envelope.worklet.js after discovery that the
// stub-zero output broke every compressor recipe that used the envelope
// op in a compiled VST3 (browser worklet works correctly; C++ stub did not).
#pragma once
#include <cmath>
#include <cstring>

namespace shags::ops {

class EnvelopeOp_{{ node_id }} {
public:
    static constexpr const char* opId = "envelope";
    // Watte denormal bias — dsp_code_canon_utilities.md §1, applied with
    // alternating sign so long-term DC of the bias is zero while idle-channel
    // tails never cause subnormal-trap stalls.
    static constexpr double DENORM = 1e-20;

    explicit EnvelopeOp_{{ node_id }}(double sampleRate) : sr_(sampleRate) {
        recomputeAlphas();
    }

    void reset() { state_ = 0.0; denormSign_ = false; }

    void setParam(const char* id, double v) {
        if (!std::isfinite(v)) return;
        if (std::strcmp(id, "attack") == 0) {
            attackMs_ = v; recomputeAlphas();
        } else if (std::strcmp(id, "release") == 0) {
            releaseMs_ = v; recomputeAlphas();
        } else if (std::strcmp(id, "amount") == 0) {
            amount_ = v;
        } else if (std::strcmp(id, "offset") == 0) {
            offset_ = v;
        }
    }

    int getLatencySamples() const { return 0; }

    // in:  mono input (typically rectified)
    // env: mono control-rate output  (offset + amount * smoothed_state)
    void process(const float* in, float* env, int N) {
        if (in == nullptr) {
            const float ofs = static_cast<float>(offset_);
            for (int i = 0; i < N; ++i) env[i] = ofs;
            return;
        }
        const double aAtt   = atkAlpha_;
        const double aRel   = relAlpha_;
        const double amount = amount_;
        const double offset = offset_;
        double s  = state_;
        double dn = denormSign_ ? DENORM : -DENORM;
        for (int i = 0; i < N; ++i) {
            const double x = std::fabs(static_cast<double>(in[i]));
            const double a = (x > s) ? aAtt : aRel;
            s  = a * s + (1.0 - a) * x;
            dn = -dn;
            s += dn;                         // alternating-sign Watte bias
            env[i] = static_cast<float>(offset + amount * s);
        }
        state_      = s;
        denormSign_ = (dn > 0.0);
    }

private:
    void recomputeAlphas() {
        const double atkSec = std::fmax(1e-4, attackMs_  / 1000.0);
        const double relSec = std::fmax(1e-4, releaseMs_ / 1000.0);
        atkAlpha_ = std::exp(-1.0 / (atkSec * sr_));
        relAlpha_ = std::exp(-1.0 / (relSec * sr_));
    }

    double sr_;
    double attackMs_  = 5.0;
    double releaseMs_ = 120.0;
    double amount_    = -1.0;
    double offset_    = 0.0;
    double state_     = 0.0;
    double atkAlpha_  = 0.0;
    double relAlpha_  = 0.0;
    bool   denormSign_ = false;
};

}  // namespace shags::ops
