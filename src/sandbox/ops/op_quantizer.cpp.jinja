// op_quantizer.cpp.jinja — Stage-3 native mirror of op_quantizer.worklet.js.
//
// Snap-to-grid quantizer for control signals. See worklet header for
// full design rationale.

#pragma once
#include <cmath>
#include <cstring>

namespace shags {

struct QuantizerOp {
    static constexpr const char* opId = "quantizer";

    double sr     = 48000.0;
    double step   = 0.125;
    double offset = 0.0;
    int    mode   = 0;   // 0 = round, 1 = floor, 2 = ceil

    explicit QuantizerOp(double sampleRate) : sr(sampleRate) {}

    void reset() { /* stateless */ }

    void setParam(const char* id, double v) {
        if (!std::isfinite(v)) return;
        if (std::strcmp(id, "step") == 0) {
            step = v < 0.0 ? -v : v;
        } else if (std::strcmp(id, "offset") == 0) {
            offset = v;
        } else if (std::strcmp(id, "mode") == 0) {
            int m = (int)std::round(v);
            mode = (m == 1 || m == 2) ? m : 0;
        }
    }

    void setParamStr(const char* id, const char* s) {
        if (std::strcmp(id, "mode") != 0) return;
        if      (std::strcmp(s, "round") == 0) mode = 0;
        else if (std::strcmp(s, "floor") == 0) mode = 1;
        else if (std::strcmp(s, "ceil")  == 0) mode = 2;
    }

    int getLatencySamples() const { return 0; }

    void process(const float* in, float* out, int N) {
        if (!out) return;
        const double s   = step;
        const double off = offset;
        const int    m   = mode;

        if (!in) {
            if (s == 0.0) { for (int i = 0; i < N; ++i) out[i] = 0.0f; return; }
            double t = -off / s;
            double q;
            if      (m == 1) q = std::floor(t);
            else if (m == 2) q = std::ceil(t);
            else             q = std::round(t);
            float v = (float)(off + q * s);
            for (int i = 0; i < N; ++i) out[i] = v;
            return;
        }

        if (s == 0.0) {
            for (int i = 0; i < N; ++i) out[i] = in[i];
            return;
        }

        const double inv = 1.0 / s;
        if (m == 1) {
            for (int i = 0; i < N; ++i) out[i] = (float)(off + std::floor(((double)in[i] - off) * inv) * s);
        } else if (m == 2) {
            for (int i = 0; i < N; ++i) out[i] = (float)(off + std::ceil (((double)in[i] - off) * inv) * s);
        } else {
            for (int i = 0; i < N; ++i) out[i] = (float)(off + std::round(((double)in[i] - off) * inv) * s);
        }
    }
};

} // namespace shags
