// op_msEncode.cpp.jinja — Stage-3 native mirror of op_msEncode.worklet.js.
//
// Blumlein 1933 sum-and-difference matrix (encode-only): M=(L+R)/2, S=(L-R)/2.
// In-repo precedent: src/core/dspWorklet.js:1043–1044 (WidthModule).
// Catalog #22. Mirrors the worklet bit-for-bit.
#pragma once

namespace shags::ops {

class MsEncodeOp_{{ node_id }} {
public:
    static constexpr const char* opId = "msEncode";

    explicit MsEncodeOp_{{ node_id }}(double sampleRate) : sr_(sampleRate) {}

    void reset() {}
    void setParam(const char*, double) {}
    int  getLatencySamples() const { return 0; }

    void process(const float* inL, const float* inR,
                 float* outM, float* outS, int N) {
        for (int i = 0; i < N; ++i) {
            const float l = inL ? inL[i] : 0.0f;
            const float r = inR ? inR[i] : 0.0f;
            if (outM) outM[i] = (l + r) * 0.5f;
            if (outS) outS[i] = (l - r) * 0.5f;
        }
    }

private:
    double sr_ = 0.0;
};

} // namespace shags::ops
