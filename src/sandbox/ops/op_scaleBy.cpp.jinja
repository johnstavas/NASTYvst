#pragma once
#include <cstring>
#include <cmath>

namespace shags::ops {

class ScaleByOp_{{ node_id }} {
public:
    static constexpr const char* opId = "scaleBy";

    explicit ScaleByOp_{{ node_id }}(double sampleRate) : sr_(sampleRate) {}

    void reset() {}

    void setParam(const char* id, double v) {
        if (std::strcmp(id, "k") == 0) {
            k_ = std::isfinite(v) ? v : 1.0;
        }
    }

    int getLatencySamples() const { return 0; }

    void process(const float* in, float* out, int N) {
        if (!out) return;
        if (!in) { for (int i = 0; i < N; ++i) out[i] = 0.0f; return; }
        const double k = k_;
        if (k == 1.0) {
            for (int i = 0; i < N; ++i) out[i] = in[i];
            return;
        }
        if (k == 0.0) {
            for (int i = 0; i < N; ++i) out[i] = 0.0f;
            return;
        }
        for (int i = 0; i < N; ++i) out[i] = static_cast<float>(k * in[i]);
    }

private:
    double sr_;
    double k_ = 1.0;
};

}  // namespace shags::ops
