#pragma once
#include <cstring>

namespace shags::ops {

class UniBiOp_{{ node_id }} {
public:
    static constexpr const char* opId = "uniBi";
    static constexpr int MODE_UNI_TO_BI = 0;
    static constexpr int MODE_BI_TO_UNI = 1;

    explicit UniBiOp_{{ node_id }}(double sampleRate)
        : sr_(sampleRate), mode_(MODE_UNI_TO_BI) {}

    void reset() {}

    void setParam(const char* id, double v) {
        if (!id) return;
        if (std::strcmp(id, "mode") == 0) {
            // Numeric form only in C++ (strings marshalled through
            // codegen canonicalization). 0 = uniToBi, 1 = biToUni.
            if (v == 0.0)      mode_ = MODE_UNI_TO_BI;
            else if (v == 1.0) mode_ = MODE_BI_TO_UNI;
        }
    }

    int getLatencySamples() const { return 0; }

    void process(const float* in, float* out, int N) {
        if (!out) return;
        if (!in) {
            const float fill = (mode_ == MODE_UNI_TO_BI) ? -1.0f : 0.5f;
            for (int i = 0; i < N; ++i) out[i] = fill;
            return;
        }
        if (mode_ == MODE_UNI_TO_BI) {
            for (int i = 0; i < N; ++i) out[i] = 2.0f * in[i] - 1.0f;
        } else {
            for (int i = 0; i < N; ++i) out[i] = (in[i] + 1.0f) * 0.5f;
        }
    }

private:
    double sr_;
    int    mode_;
};

}  // namespace shags::ops
