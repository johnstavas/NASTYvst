// op_tilt.cpp.jinja — Stage-3 native mirror of op_tilt.worklet.js.
//
// Tilt EQ. Primary: musicdsp archive #267 "Simple Tilt Equalizer"
// (Lubomir I. Ivanov, 2009). Catalog #38. Mirrors the worklet bit-for-bit.
#pragma once
#include <cstring>
#include <cmath>
#include <algorithm>

namespace shags::ops {

class TiltOp_{{ node_id }} {
public:
    static constexpr const char* opId = "tilt";

    explicit TiltOp_{{ node_id }}(double sampleRate) : sr_(sampleRate) {
        recalc();
    }

    void reset() { lp_out_ = 0.0; }

    void setParam(const char* id, double v) {
        if (!std::isfinite(v)) return;
        if (!std::strcmp(id, "f0")) {
            f0_ = std::clamp(v, 1.0, sr_ * 0.49);
        } else if (!std::strcmp(id, "gain")) {
            gain_ = std::clamp(v, -24.0, 24.0);
        } else if (!std::strcmp(id, "gfactor")) {
            gfactor_ = std::clamp(v, 0.01, 100.0);
        } else {
            return;
        }
        recalc();
    }

    int getLatencySamples() const { return 0; }

    void process(const float* in, float* out, int N) {
        if (!out) return;
        const double a0 = a0_, b1 = b1_;
        const double lgain = lgain_, hgain = hgain_;
        double lp = lp_out_;
        for (int i = 0; i < N; ++i) {
            double x = in ? (double)in[i] : 0.0;
            lp = a0 * x + b1 * lp;
            if (lp > -DENORMAL && lp < DENORMAL) lp = 0.0;
            out[i] = (float)(x + lgain * lp + hgain * (x - lp));
        }
        lp_out_ = lp;
    }

private:
    static constexpr double DENORMAL = 1e-30;

    void recalc() {
        double amp = 6.0 / std::log(2.0);
        double sr3 = 3.0 * sr_;
        double g1, g2;
        if (gain_ > 0.0) {
            g1 = -gfactor_ * gain_; g2 = gain_;
        } else {
            g1 = -gain_;            g2 = gfactor_ * gain_;
        }
        lgain_ = std::exp(g1 / amp) - 1.0;
        hgain_ = std::exp(g2 / amp) - 1.0;

        double omega = 2.0 * M_PI * f0_;
        double n     = 1.0 / (sr3 + omega);
        a0_          = 2.0 * omega * n;
        b1_          = (sr3 - omega) * n;
    }

    double sr_      = 0.0;
    double f0_      = 630.0;
    double gain_    = 0.0;
    double gfactor_ = 5.0;
    double lgain_   = 0.0;
    double hgain_   = 0.0;
    double a0_      = 0.0;
    double b1_      = 0.0;
    double lp_out_  = 0.0;
};

} // namespace shags::ops
