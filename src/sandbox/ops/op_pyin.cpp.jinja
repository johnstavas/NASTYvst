static constexpr float HMM_MIN_FREQ = 61.735f;
static constexpr int   HMM_N_BPS    = 5;
static constexpr int   HMM_N_PITCH  = 69 * HMM_N_BPS;           // 345
static constexpr int   HMM_TRANS_W  = 5 * (HMM_N_BPS / 2) + 1;  // 11

} // namespace shags_pyin_{{ instance }}

struct OpPyin_{{ instance }} {
    using NS = shags_pyin_{{ instance }};

    float sr = 48000.0f;
    float p_f0Min = 61.735f, p_f0Max = 880.0f;
    float p_windowMs = 46.4f, p_hopMs = 5.8f;
    int   p_prior = 2;
    float p_yinTrust = 0.5f, p_selfTrans = 0.99f;
    int   p_lagFrames = 8;

    int W = 2048, hop = 256, tauMin = 48, tauMax = 600;
    std::vector<float> buf;
    int bufMask = 0, w = 0, filled = 0;

    std::vector<float> frame, df, cmndf, peakProb;

    // HMM state
    static constexpr int M = NS::HMM_N_PITCH;
    static constexpr int N_STATE = 2 * M;
    float hmmFreqs[N_STATE];
    std::vector<int>   trFrom, trTo;
    std::vector<float> trProb;
    float init[N_STATE];
    float delta[N_STATE];
    float oldDelta[N_STATE];
    float obsScratch[N_STATE];
    // Fixed-lag ring of psi[t] → preceding-state index per state.
    std::vector<std::vector<int>> psiRing;
    bool  hmmInitialized = false;

    float lastF0 = 0.0f, lastVoicedProb = 0.0f, lastVoicedFlag = 0.0f;

    void recompute() {
        W      = std::max(32, (int)std::round(p_windowMs * 0.001f * sr));
        hop    = std::max(1,  (int)std::round(p_hopMs    * 0.001f * sr));
        tauMin = std::max(2,        (int)std::floor(sr / p_f0Max));
        tauMax = std::min(W - 1,    (int)std::ceil (sr / p_f0Min));
        if (tauMax <= tauMin) tauMax = tauMin + 1;

        int frameLen = W + tauMax + 2;
        int n = 1; while (n < frameLen + 2) n <<= 1;
        buf.assign(n, 0.0f);
        bufMask = n - 1; w = 0; filled = 0;

        frame.assign(frameLen, 0.0f);
        df.assign(tauMax + 1, 0.0f);
        cmndf.assign(tauMax + 1, 0.0f);
        peakProb.assign(tauMax + 1, 0.0f);
    }

    void buildHMM() {
        const int halfW = NS::HMM_TRANS_W / 2;
        const float self_ = p_selfTrans;

        for (int i = 0; i < M; ++i) {
            hmmFreqs[i]     = NS::HMM_MIN_FREQ * std::pow(2.0f, (float)i / (12.0f * NS::HMM_N_BPS));
            hmmFreqs[i + M] = -hmmFreqs[i];
        }

        trFrom.clear(); trTo.clear(); trProb.clear();
        for (int iPitch = 0; iPitch < M; ++iPitch) {
            int theoreticalMinNext = iPitch - halfW;
            int minNext = std::max(0, theoreticalMinNext);
            int maxNext = std::min(M - 1, iPitch + halfW);

            float weightSum = 0;
            std::vector<float> weights;
            weights.reserve(maxNext - minNext + 1);
            for (int i = minNext; i <= maxNext; ++i) {
                float wv = (i <= iPitch)
                    ? (float)(i - theoreticalMinNext + 1)
                    : (float)(iPitch - theoreticalMinNext + 1 - (i - iPitch));
                weights.push_back(wv);
                weightSum += wv;
            }
            for (int i = minNext; i <= maxNext; ++i) {
                float wv = weights[i - minNext] / weightSum;
                trFrom.push_back(iPitch);       trTo.push_back(i);          trProb.push_back(wv * self_);
                trFrom.push_back(iPitch);       trTo.push_back(i + M);      trProb.push_back(wv * (1.0f - self_));
                trFrom.push_back(iPitch + M);   trTo.push_back(i + M);      trProb.push_back(wv * self_);
                trFrom.push_back(iPitch + M);   trTo.push_back(i);          trProb.push_back(wv * (1.0f - self_));
            }
        }

        const float invN = 1.0f / (float)N_STATE;
        for (int s = 0; s < N_STATE; ++s) {
            init[s]     = invN;
            delta[s]    = 0.0f;
            oldDelta[s] = 0.0f;
        }
        psiRing.clear();
        hmmInitialized = false;
    }

    void setSampleRate(float s) { sr = s; recompute(); buildHMM(); }

    void reset() {
        std::fill(buf.begin(), buf.end(), 0.0f);
        std::fill(frame.begin(), frame.end(), 0.0f);
        std::fill(df.begin(), df.end(), 0.0f);
        std::fill(cmndf.begin(), cmndf.end(), 0.0f);
        std::fill(peakProb.begin(), peakProb.end(), 0.0f);
        w = 0; filled = 0;
        lastF0 = 0; lastVoicedProb = 0; lastVoicedFlag = 0;
        for (int s = 0; s < N_STATE; ++s) { delta[s] = 0; oldDelta[s] = 0; }
        psiRing.clear();
        hmmInitialized = false;
    }

    void setParam_f0Min    (float v){ if(std::isfinite(v)){ p_f0Min     = std::clamp(v, 20.0f, 500.0f);   recompute(); } }
    void setParam_f0Max    (float v){ if(std::isfinite(v)){ p_f0Max     = std::clamp(v, 200.0f, sr*0.25f); recompute(); } }
    void setParam_windowMs (float v){ if(std::isfinite(v)){ p_windowMs  = std::clamp(v, 10.0f, 200.0f);    recompute(); } }
    void setParam_hopMs    (float v){ if(std::isfinite(v)){ p_hopMs     = std::clamp(v, 1.0f,  50.0f);     recompute(); } }
    void setParam_prior    (float v){ if(std::isfinite(v)){ p_prior     = std::clamp((int)v, 0, 4); } }
    void setParam_yinTrust (float v){ if(std::isfinite(v)){ p_yinTrust  = std::clamp(v, 0.0f, 1.0f); } }
    void setParam_selfTrans(float v){ if(std::isfinite(v)){ p_selfTrans = std::clamp(v, 0.0f, 1.0f); buildHMM(); } }
    void setParam_lagFrames(float v){ if(std::isfinite(v)){ p_lagFrames = std::clamp((int)v, 1, 64); } }

    void computeFrame() {
        const int frameLen = W + tauMax;

        int rd = (w - frameLen) & bufMask;
        for (int i = 0; i < frameLen; ++i) { frame[i] = buf[rd]; rd = (rd + 1) & bufMask; }

        float energy = 0;
        for (int j = 0; j < W; ++j) energy += frame[j] * frame[j];
        if (energy < 1e-10f) { lastF0 = 0; lastVoicedProb = 0; lastVoicedFlag = 0; return; }

        // YIN d(τ)
        df[0] = 0;
        for (int tau = 1; tau <= tauMax; ++tau) {
            float s = 0;
            for (int j = 0; j < W; ++j) {
                float d = frame[j] - frame[j + tau];
                s += d * d;
            }
            df[tau] = s;
        }
        // CMNDF
        cmndf[0] = 1;
        float runSum = 0;
        for (int tau = 1; tau <= tauMax; ++tau) {
            runSum += df[tau];
            cmndf[tau] = (runSum > 0) ? (df[tau] * tau / runSum) : 1.0f;
        }

        // pYIN Stage 1: probabilistic thresholding.
        std::fill(peakProb.begin(), peakProb.end(), 0.0f);
        const float* dist = NS::DIST_TABLE[p_prior];
        const int nThr = 100;
        const float maxThresh = 0.01f + 0.01f * (nThr - 1);
        float minVal = std::numeric_limits<float>::infinity();
        int   minInd = 0;
        float sumProb = 0;

        int tau = tauMin;
        while (tau + 1 < tauMax) {
            if (cmndf[tau] < maxThresh && cmndf[tau + 1] < cmndf[tau]) {
                while (tau + 1 < tauMax && cmndf[tau + 1] < cmndf[tau]) ++tau;
                if (cmndf[tau] < minVal && tau > 2) { minVal = cmndf[tau]; minInd = tau; }
                int ci = nThr - 1;
                const float dp = cmndf[tau];
                while (ci >= 0 && (0.01f + 0.01f * ci) > dp) {
                    peakProb[tau] += dist[ci];
                    --ci;
                }
                sumProb += peakProb[tau];
                ++tau;
            } else {
                ++tau;
            }
        }

        if (sumProb > 0 && peakProb[minInd] > 0) {
            const float scale = peakProb[minInd] / sumProb;
            for (int i = tauMin; i < tauMax; ++i) peakProb[i] *= scale;
        }

        // Stage 2 observation probs per HMM state.
        for (int s = 0; s < N_STATE; ++s) obsScratch[s] = 0;
        float probYinPitched = 0;

        for (int tauC = tauMin; tauC < tauMax; ++tauC) {
            float p = peakProb[tauC];
            if (p <= 0) continue;
            float tauR = (float)tauC;
            if (tauC > 0 && tauC < tauMax) {
                float y0 = cmndf[tauC - 1], y1 = cmndf[tauC], y2 = cmndf[tauC + 1];
                float den = 2.0f * (y0 - 2.0f * y1 + y2);
                if (den != 0.0f) {
                    float d = (y0 - y2) / den;
                    if (d > -1.0f && d < 1.0f) tauR = (float)tauC + d;
                }
            }
            float f = sr / tauR;
            if (f <= NS::HMM_MIN_FREQ) continue;
            float oldd = 1e9f;
            for (int iPitch = 0; iPitch < M; ++iPitch) {
                float d = std::fabs(f - hmmFreqs[iPitch]);
                if (oldd < d && iPitch > 0) {
                    obsScratch[iPitch - 1] += p;
                    probYinPitched += p;
                    break;
                }
                oldd = d;
            }
        }

        const float probReallyPitched = p_yinTrust * probYinPitched;
        if (probYinPitched > 0) {
            const float scale = probReallyPitched / probYinPitched; // = yinTrust
            for (int iPitch = 0; iPitch < M; ++iPitch) obsScratch[iPitch] *= scale;
        }
        const float unvoicedMass = (1.0f - probReallyPitched) / (float)M;
        for (int iPitch = 0; iPitch < M; ++iPitch) obsScratch[iPitch + M] = unvoicedMass;

        // Forward Viterbi step.
        if (!hmmInitialized) {
            float dsum = 0;
            for (int s = 0; s < N_STATE; ++s) {
                oldDelta[s] = init[s] * obsScratch[s];
                dsum += oldDelta[s];
            }
            if (dsum > 0) for (int s = 0; s < N_STATE; ++s) oldDelta[s] /= dsum;
            else          for (int s = 0; s < N_STATE; ++s) oldDelta[s] = 1.0f / (float)N_STATE;
            psiRing.emplace_back(N_STATE, 0);
            hmmInitialized = true;
            return;
        }

        std::vector<int> tempPsi(N_STATE, 0);
        for (int s = 0; s < N_STATE; ++s) delta[s] = 0;
        const int nTrans = (int)trProb.size();
        for (int t = 0; t < nTrans; ++t) {
            int   fs = trFrom[t], ts = trTo[t];
            float v  = oldDelta[fs] * trProb[t];
            if (v > delta[ts]) { delta[ts] = v; tempPsi[ts] = fs; }
        }
        float dsum = 0;
        for (int s = 0; s < N_STATE; ++s) { delta[s] *= obsScratch[s]; dsum += delta[s]; }
        if (dsum > 0) for (int s = 0; s < N_STATE; ++s) { oldDelta[s] = delta[s] / dsum; delta[s] = 0; }
        else          for (int s = 0; s < N_STATE; ++s) { oldDelta[s] = 1.0f / (float)N_STATE; delta[s] = 0; }

        psiRing.push_back(std::move(tempPsi));
        while ((int)psiRing.size() > p_lagFrames + 1) psiRing.erase(psiRing.begin());

        int bestState = 0; float bestVal = -1.0f;
        for (int s = 0; s < N_STATE; ++s) if (oldDelta[s] > bestVal) { bestVal = oldDelta[s]; bestState = s; }
        int state = bestState;
        for (int f = (int)psiRing.size() - 1; f > 0; --f) state = psiRing[f][state];

        bool voiced = (state < M);
        int pitchBin = voiced ? state : (state - M);
        lastVoicedFlag = voiced ? 1.0f : 0.0f;
        lastF0 = voiced ? hmmFreqs[pitchBin] : 0.0f;
        lastVoicedProb = std::clamp(probReallyPitched, 0.0f, 1.0f);
    }

    void process(const float* in, float* f0Out, float* vpOut, float* vfOut, int N) {
        for (int n = 0; n < N; ++n) {
            float x = in ? in[n] : 0.0f;
            buf[w] = x; w = (w + 1) & bufMask; ++filled;
            if (filled >= hop) { filled = 0; computeFrame(); }
            if (f0Out) f0Out[n] = lastF0;
            if (vpOut) vpOut[n] = lastVoicedProb;
            if (vfOut) vfOut[n] = lastVoicedFlag;
        }
    }

    int getLatencySamples() const { return W + p_lagFrames * hop; }
};
