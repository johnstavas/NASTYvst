// op_tapeSim.cpp.jinja — C++ mirror of op_tapeSim.worklet.js
// Gloubi-boulga → RBJ peak → 1-pole LP. See worklet.js header.

#pragma once
#include <cmath>
#include <algorithm>

struct OpTapeSim_{{ instance }} {
    float sr = 48000.0f;
    float drive = 1.0f, bumpHz = 60.0f, bumpDb = 3.0f, bumpQ = 1.0f;
    float hfHz = 16000.0f, trim = 1.0f;
    float b0 = 1, b1 = 0, b2 = 0, a1 = 0, a2 = 0;
    float s1 = 0, s2 = 0;
    float lpA = 0, lpY = 0;

    static constexpr float DENORMAL = 1e-30f;

    void setSampleRate(float s) { sr = s; recomputeBump(); recomputeHF(); }

    void reset() { s1 = s2 = lpY = 0.0f; }

    static inline float gloubi(float in) {
        float x  = in * 0.686306f;
        float a  = 1.0f + std::exp(std::sqrt(std::fabs(x)) * -0.75f);
        float ex = std::exp(x);
        float enx= std::exp(-x);
        float exa= std::exp(-x * a);
        return (ex - exa) / (ex + enx);
    }

    void recomputeBump() {
        float A  = std::pow(10.0f, bumpDb / 40.0f);
        float w0 = 2.0f * float(M_PI) * bumpHz / sr;
        float cw = std::cos(w0), sw = std::sin(w0);
        float alpha = sw / (2.0f * bumpQ);
        float B0 = 1.0f + alpha * A;
        float B1 = -2.0f * cw;
        float B2 = 1.0f - alpha * A;
        float A0 = 1.0f + alpha / A;
        float A1 = -2.0f * cw;
        float A2 = 1.0f - alpha / A;
        float inv = 1.0f / A0;
        b0 = B0 * inv; b1 = B1 * inv; b2 = B2 * inv;
        a1 = A1 * inv; a2 = A2 * inv;
    }

    void recomputeHF() {
        if (hfHz >= sr * 0.5f) lpA = 1.0f;
        else lpA = 1.0f - std::exp(-2.0f * float(M_PI) * hfHz / sr);
    }

    void setParam_drive(float v)  { if(std::isfinite(v)) drive  = std::clamp(v, 0.0f, 20.0f); }
    void setParam_bumpHz(float v) { if(std::isfinite(v)) { bumpHz = std::clamp(v, 10.0f, sr*0.49f); recomputeBump(); } }
    void setParam_bumpDb(float v) { if(std::isfinite(v)) { bumpDb = std::clamp(v, -12.0f, 12.0f); recomputeBump(); } }
    void setParam_bumpQ(float v)  { if(std::isfinite(v)) { bumpQ  = std::clamp(v, 0.1f, 10.0f); recomputeBump(); } }
    void setParam_hfHz(float v)   { if(std::isfinite(v)) { hfHz   = std::clamp(v, 200.0f, sr*0.49f); recomputeHF(); } }
    void setParam_trim(float v)   { if(std::isfinite(v)) trim   = std::clamp(v, 0.0f, 4.0f); }

    inline void process(const float* in, float* out, int N) {
        for (int n = 0; n < N; ++n) {
            float x0 = in ? in[n] : 0.0f;
            float sat = gloubi(x0 * drive);
            float yp = b0 * sat + s1;
            s1 = b1 * sat - a1 * yp + s2;
            s2 = b2 * sat - a2 * yp;
            lpY = lpY + lpA * (yp - lpY);
            float y = lpY * trim;
            if (std::fabs(y) < DENORMAL) y = 0.0f;
            out[n] = y;
        }
        if (std::fabs(s1) < DENORMAL) s1 = 0;
        if (std::fabs(s2) < DENORMAL) s2 = 0;
        if (std::fabs(lpY) < DENORMAL) lpY = 0;
    }
};
