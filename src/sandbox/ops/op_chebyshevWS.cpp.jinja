#pragma once
#include <cstring>
#include <cmath>

namespace shags::ops {

class ChebyshevWSOp_{{ node_id }} {
public:
    static constexpr const char* opId = "chebyshevWS";

    explicit ChebyshevWSOp_{{ node_id }}(double sampleRate) : sr_(sampleRate) {}

    void reset() {}

    void setParam(const char* id, double v) {
        if (!std::isfinite(v)) return;
        const double clipped = v < -2.0 ? -2.0 : (v > 2.0 ? 2.0 : v);
        if (std::strcmp(id, "g1") == 0) g1_ = clipped;
        else if (std::strcmp(id, "g2") == 0) g2_ = clipped;
        else if (std::strcmp(id, "g3") == 0) g3_ = clipped;
        else if (std::strcmp(id, "g4") == 0) g4_ = clipped;
        else if (std::strcmp(id, "g5") == 0) g5_ = clipped;
        else if (std::strcmp(id, "level") == 0) {
            level_ = v < 0.0 ? 0.0 : (v > 4.0 ? 4.0 : v);
        }
    }

    int getLatencySamples() const { return 0; }

    void process(const float* in, float* out, int N) {
        if (!out) return;
        if (!in) { for (int i = 0; i < N; ++i) out[i] = 0.0f; return; }
        const double g1 = g1_, g2 = g2_, g3 = g3_,
                     g4 = g4_, g5 = g5_, lvl = level_;
        for (int i = 0; i < N; ++i) {
            double x = static_cast<double>(in[i]);
            if (x >  1.0) x =  1.0;
            else if (x < -1.0) x = -1.0;
            const double x2 = x * x;
            const double x3 = x2 * x;
            const double x4 = x2 * x2;
            const double x5 = x4 * x;
            const double T1 = x;
            const double T2 = 2.0 * x2 - 1.0;
            const double T3 = 4.0 * x3 - 3.0 * x;
            const double T4 = 8.0 * x4 - 8.0 * x2 + 1.0;
            const double T5 = 16.0 * x5 - 20.0 * x3 + 5.0 * x;
            out[i] = static_cast<float>(lvl * (g1 * T1 + g2 * T2 + g3 * T3 + g4 * T4 + g5 * T5));
        }
    }

private:
    double sr_;
    double g1_ = 1.0;
    double g2_ = 0.0;
    double g3_ = 0.0;
    double g4_ = 0.0;
    double g5_ = 0.0;
    double level_ = 1.0;
};

}  // namespace shags::ops
