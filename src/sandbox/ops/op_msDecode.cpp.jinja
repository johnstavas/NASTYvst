// op_msDecode.cpp.jinja — Stage-3 native mirror of op_msDecode.worklet.js.
//
// Blumlein 1933 sum-and-difference matrix (decode-only): L=M+S, R=M-S.
// In-repo precedent: src/core/dspWorklet.js:1040–1047 (WidthModule).
// Catalog #23. Mirrors the worklet bit-for-bit.
#pragma once

namespace shags::ops {

class MsDecodeOp_{{ node_id }} {
public:
    static constexpr const char* opId = "msDecode";

    explicit MsDecodeOp_{{ node_id }}(double sampleRate) : sr_(sampleRate) {}

    void reset() {}
    void setParam(const char*, double) {}
    int  getLatencySamples() const { return 0; }

    void process(const float* mid, const float* side,
                 float* outL, float* outR, int N) {
        for (int i = 0; i < N; ++i) {
            const float m = mid  ? mid[i]  : 0.0f;
            const float s = side ? side[i] : 0.0f;
            if (outL) outL[i] = m + s;
            if (outR) outR[i] = m - s;
        }
    }

private:
    double sr_ = 0.0;
};

} // namespace shags::ops
