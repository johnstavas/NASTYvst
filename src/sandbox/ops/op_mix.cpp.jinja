// op_mix.cpp — Stage-3b C++ sidecar for the `mix` op.
// Contract: memory/codegen_design.md § 4. Equal-power crossfade form per
// memory/dry_wet_mix_rule.md (NON-NEGOTIABLE): mix happens inside the same
// DSP unit, same-sample. cos/sin gives constant total power across amount.
//
// First multi-input op in the catalog — exercises codegen's N-port input
// dispatch (callExprFor emits process(dry_buf, wet_buf, out_buf, N) in the
// op's input-port-declaration order).
//
// Param ULP note: cos/sin are computed once per setParam (not per sample),
// so JS Math.cos vs native libm cos drift only affects the gain constants,
// not per-sample noise. Tolerance budget: -110 dB (between bit-exact ops
// and the trig-per-sample filters at -90).
//
// Template: Jinja2. {{ graph_id }} / {{ node_id }} injected by emitter.
#pragma once
#include <cstring>
#include <cmath>

namespace shags::ops {

class MixOp_{{ node_id }} {
public:
    static constexpr const char* opId = "mix";

    explicit MixOp_{{ node_id }}(double sampleRate) : sr_(sampleRate) {
        recomputeGains();
    }

    void reset() {
        dryGSmoothed_ = -1.0;   // <0 sentinel: prime on first block
        wetGSmoothed_ = -1.0;
    }

    void setParam(const char* id, double v) {
        if (std::strcmp(id, "amount") == 0) {
            amount_ = v < 0.0 ? 0.0 : (v > 1.0 ? 1.0 : v);
            recomputeGains();
        }
    }

    int getLatencySamples() const { return 0; }

    // dry / wet: both mono inputs (either may be nullptr -> treat as 0).
    // PER-SAMPLE smoothing of dryG/wetG to kill knob-twiddle clicks (added
    // 2026-04-27, mirrors op_gain smoothing).  Without smoothing, dragging
    // the MIX knob produces a per-block step in dry/wet gain that audibly
    // clicks.
    void process(const float* dry, const float* wet, float* out, int N) {
        if (!out) return;
        if (dryGSmoothed_ < 0.0) { dryGSmoothed_ = dryGTarget_; wetGSmoothed_ = wetGTarget_; }
        const double dInc = (dryGTarget_ - dryGSmoothed_) / (N > 0 ? N : 1);
        const double wInc = (wetGTarget_ - wetGSmoothed_) / (N > 0 ? N : 1);
        double dG = dryGSmoothed_;
        double wG = wetGSmoothed_;
        if (!dry && !wet) {
            for (int i = 0; i < N; ++i) out[i] = 0.0f;
            dryGSmoothed_ = dryGTarget_; wetGSmoothed_ = wetGTarget_;
            return;
        }
        if (!dry) {
            for (int i = 0; i < N; ++i) {
                wG += wInc;
                out[i] = static_cast<float>(wG * static_cast<double>(wet[i]));
            }
        } else if (!wet) {
            for (int i = 0; i < N; ++i) {
                dG += dInc;
                out[i] = static_cast<float>(dG * static_cast<double>(dry[i]));
            }
        } else {
            for (int i = 0; i < N; ++i) {
                dG += dInc; wG += wInc;
                out[i] = static_cast<float>(dG * static_cast<double>(dry[i])
                                          + wG * static_cast<double>(wet[i]));
            }
        }
        dryGSmoothed_ = dryGTarget_;
        wetGSmoothed_ = wetGTarget_;
    }

private:
    void recomputeGains() {
        dryGTarget_ = std::cos(amount_ * M_PI * 0.5);
        wetGTarget_ = std::sin(amount_ * M_PI * 0.5);
    }

    double sr_;
    double amount_       = 0.5;
    double dryGTarget_   = 0.7071067811865476;     // cos(π/4)
    double wetGTarget_   = 0.7071067811865476;     // sin(π/4)
    double dryGSmoothed_ = -1.0;                   // primes on first block
    double wetGSmoothed_ = -1.0;
};

}  // namespace shags::ops
