// op_randomWalk.cpp.jinja — C++ mirror of op_randomWalk.worklet.js.
// SC BrownNoise_next algorithm over feldkirch PRNG.

#pragma once
#include <cmath>
#include <cstring>
#include <algorithm>
#include <cstdint>

namespace shags::ops {

class RandomWalkOp_{{ node_id }} {
public:
    static constexpr const char* opId = "randomWalk";
    explicit RandomWalkOp_{{ node_id }}(double sampleRate) { setSampleRate((float)sampleRate); }
    static constexpr float SCALE = 2.0f / (float)0xffffffffu;

    float sr      = 48000.0f;
    float p_step  = 0.125f;
    float p_level = 1.0f;
    float z       = 0.0f;
    int32_t x1 = (int32_t)0x67452301;
    int32_t x2 = (int32_t)0xefcdab89;

    void setSampleRate(float s) { sr = s; }
    void reset() {
        z  = 0.0f;
        x1 = (int32_t)0x67452301;
        x2 = (int32_t)0xefcdab89;
    }

    void setParam_step(float v) {
        if (std::isfinite(v)) p_step = std::clamp(v, 0.0001f, 0.5f);
    }
    void setParam_level(float v) {
        if (std::isfinite(v)) p_level = std::clamp(v, 0.0f, 1.0f);
    }

    void process(float* out, int N) {
        if (!out) return;
        const float step = p_step;
        const float lvl  = p_level;
        for (int n = 0; n < N; ++n) {
            x1 = x1 ^ x2;
            const float u = (float)x2 * SCALE;
            x2 = x2 + x1;
            z += u * step;
            if      (z >  1.0f) z =  2.0f - z;
            else if (z < -1.0f) z = -2.0f - z;
            out[n] = z * lvl;
        }
    }

    int getLatencySamples() const { return 0; }

    // Dispatch entry-point used by MasterGraph (matches canonical convention).
    void setParam(const char* id, double v) {
        if      (std::strcmp(id, "step") == 0) setParam_step((float)v);
        else if (std::strcmp(id, "level") == 0) setParam_level((float)v);
        // unknown ids: defensive ignore
    }
};

}  // namespace shags::ops
