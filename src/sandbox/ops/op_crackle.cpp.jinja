// op_crackle.cpp.jinja — C++ mirror of op_crackle.worklet.js.
// SC Dust/Dust2 algorithm over feldkirch PRNG (musicdsp #216).

#pragma once
#include <cmath>
#include <cstring>
#include <algorithm>
#include <cstdint>

namespace shags::ops {

class CrackleOp_{{ node_id }} {
public:
    static constexpr const char* opId = "crackle";
    explicit CrackleOp_{{ node_id }}(double sampleRate) { setSampleRate((float)sampleRate); }
    static constexpr float SCALE = 2.0f / (float)0xffffffffu;

    float sr        = 48000.0f;
    float p_density = 100.0f;
    int   p_mode    = 1;
    float p_level   = 0.0f;
    float lvlLin    = 1.0f;
    float thresh    = 100.0f / 48000.0f;
    float scl       = 2.0f / thresh;

    int32_t x1 = (int32_t)0x67452301;
    int32_t x2 = (int32_t)0xefcdab89;

    void setSampleRate(float s) {
        sr = s;
        recalc();
    }
    void reset() {
        x1 = (int32_t)0x67452301;
        x2 = (int32_t)0xefcdab89;
    }

    void recalc() {
        const float nyq = sr * 0.5f;
        const float d = std::clamp(p_density, 0.01f, nyq);
        thresh = d / sr;
        scl = thresh > 0.0f ? ((p_mode == 1) ? (2.0f / thresh) : (1.0f / thresh)) : 0.0f;
    }

    void setParam_density(float v) {
        if (std::isfinite(v)) { p_density = v; recalc(); }
    }
    void setParam_mode(float v) {
        if (std::isfinite(v)) { p_mode = ((int)v == 1) ? 1 : 0; recalc(); }
    }
    void setParam_level(float v) {
        if (std::isfinite(v)) {
            p_level = std::clamp(v, -60.0f, 0.0f);
            lvlLin  = std::pow(10.0f, p_level / 20.0f);
        }
    }

    void process(float* out, int N) {
        if (!out) return;
        const float th  = thresh;
        const float sc  = scl;
        const float lvl = lvlLin;
        const bool  bi  = (p_mode == 1);
        for (int n = 0; n < N; ++n) {
            x1 = x1 ^ x2;
            const float u = (float)x2 * SCALE;     // [-1, 1)
            x2 = x2 + x1;
            const float z = (u + 1.0f) * 0.5f;     // [0, 1)
            float y;
            if (z < th) y = bi ? (z * sc - 1.0f) : (z * sc);
            else        y = 0.0f;
            out[n] = y * lvl;
        }
    }

    int getLatencySamples() const { return 0; }

    // Dispatch entry-point used by MasterGraph (matches canonical convention).
    void setParam(const char* id, double v) {
        if      (std::strcmp(id, "density") == 0) setParam_density((float)v);
        else if (std::strcmp(id, "mode") == 0) setParam_mode((float)v);
        else if (std::strcmp(id, "level") == 0) setParam_level((float)v);
        // unknown ids: defensive ignore
    }
};

}  // namespace shags::ops
