// op_formant.cpp.jinja — Stage-3 native mirror of op_formant.worklet.js.
//
// Vowel-formant filter. Primary: musicdsp archive #110 (alex@smartelectronix,
// 2002). 10th-order all-pole IIR with precomputed A/E/I/O/U tables.
// Catalog #35. Mirrors the worklet bit-for-bit.
#pragma once
#include <cstring>
#include <cmath>
#include <array>
#include <algorithm>

namespace shags::ops {

class FormantOp_{{ node_id }} {
public:
    static constexpr const char* opId = "formant";

    explicit FormantOp_{{ node_id }}(double sampleRate) : sr_(sampleRate) {
        memory_.fill(0.0);
        updateCoefs(0.0);
    }

    void reset() {
        memory_.fill(0.0);
    }

    void setParam(const char* id, double v) {
        if (!std::isfinite(v)) return;
        if (!std::strcmp(id, "vowel")) {
            double vc = std::clamp(v, 0.0, (double)(N_VOWELS - 1));
            if (vc != vowel_) {
                vowel_ = vc;
                updateCoefs(vc);
            }
        }
    }

    int getLatencySamples() const { return 0; }

    void process(const float* in, float* out, int N) {
        if (!out) return;
        for (int i = 0; i < N; ++i) {
            double x = in ? (double)in[i] : 0.0;

            double res = coef_[0] * x
                       + coef_[1] * memory_[0] + coef_[2] * memory_[1]
                       + coef_[3] * memory_[2] + coef_[4] * memory_[3]
                       + coef_[5] * memory_[4] + coef_[6] * memory_[5]
                       + coef_[7] * memory_[6] + coef_[8] * memory_[7]
                       + coef_[9] * memory_[8] + coef_[10] * memory_[9];

            if (res > -DENORMAL && res < DENORMAL) res = 0.0;

            memory_[9] = memory_[8]; memory_[8] = memory_[7]; memory_[7] = memory_[6];
            memory_[6] = memory_[5]; memory_[5] = memory_[4]; memory_[4] = memory_[3];
            memory_[3] = memory_[2]; memory_[2] = memory_[1]; memory_[1] = memory_[0];
            memory_[0] = res;

            out[i] = (float)res;
        }
    }

private:
    static constexpr double DENORMAL = 1e-30;
    static constexpr int    N_VOWELS = 5;

    // Vowel coefficient tables (verbatim from musicdsp #110).
    static constexpr std::array<std::array<double, 11>, 5> COEFFS = {{
        // A
        {{8.11044e-06, 8.943665402, -36.83889529, 92.01697887, -154.337906,
          181.6233289, -151.8651235, 89.09614114, -35.10298511, 8.388101016,
          -0.923313471}},
        // E
        {{4.36215e-06, 8.90438318, -36.55179099, 91.05750846, -152.422234,
          179.1170248, -149.6496211, 87.78352223, -34.60687431, 8.282228154,
          -0.914150747}},
        // I
        {{3.33819e-06, 8.893102966, -36.49532826, 90.96543286, -152.4545478,
          179.4835618, -150.315433, 88.43409371, -34.98612086, 8.407803364,
          -0.932568035}},
        // O
        {{1.13572e-06, 8.994734087, -37.2084849, 93.22900521, -156.6929844,
          184.596544, -154.3755513, 90.49663749, -35.58964535, 8.478996281,
          -0.929252233}},
        // U
        {{4.09431e-07, 8.997322763, -37.20218544, 93.11385476, -156.2530937,
          183.7080141, -153.2631681, 89.59539726, -35.12454591, 8.338655623,
          -0.910251753}},
    }};

    void updateCoefs(double v) {
        int i0 = (int)std::floor(v);
        int i1 = std::min(i0 + 1, N_VOWELS - 1);
        double t = v - i0;
        const auto& a = COEFFS[i0];
        const auto& b = COEFFS[i1];
        for (int k = 0; k < 11; ++k) {
            coef_[k] = a[k] * (1.0 - t) + b[k] * t;
        }
    }

    double sr_ = 0.0;
    double vowel_ = 0.0;
    std::array<double, 11> coef_{};
    std::array<double, 10> memory_{};
};

} // namespace shags::ops
