// op_ladder.cpp — Stage-3b C++ sidecar for the `ladder` op (v3).
// Contract: memory/codegen_design.md § 4. Mirrors op_ladder.worklet.js
// bit-for-bit. v3 (2026-04-25): Stinchcombe-direct rewrite — TPT
// trapezoidal one-pole per stage with pre-warping, 5 tanhs at the
// circuit-correct locations (1 driver + 4 stages), 2× polyphase OS
// (63-tap Kaiser β=10 halfband, latency 31 samples). Primary:
// docs/primary_sources/stinchcombe/Moog_ladder_tf.pdf §2.1.1 eq.(5),
// §2.1.2 eq.(13), §2.3 eq.(21), §2.5 fig.9.
// Template: Jinja2. {{ graph_id }} / {{ node_id }} injected by emitter.
#pragma once
#include <cstring>
#include <cmath>
#include <array>
#include <algorithm>

namespace shags::ops {

class LadderOp_{{ node_id }} {
public:
    static constexpr const char* opId = "ladder";

    explicit LadderOp_{{ node_id }}(double sampleRate) : sr_(sampleRate) {
        designHalfband();
        recomputeCoefs();
    }

    void reset() {
        y1_ = y2_ = y3_ = y4_ = 0.0;
        s1_ = s2_ = s3_ = s4_ = 0.0;
        y4_prev_ = 0.0;
        upBuf_.fill(0.0);
        dnBuf_.fill(0.0);
        upIdx_ = 0;
        dnIdx_ = 0;
    }

    void setParam(const char* id, double v) {
        if      (std::strcmp(id, "cutoff")    == 0) { cutoff_    = v; recomputeCoefs(); }
        else if (std::strcmp(id, "resonance") == 0) { resonance_ = v; recomputeCoefs(); }
        else if (std::strcmp(id, "drive")     == 0) { drive_     = v; }
        else if (std::strcmp(id, "trim")      == 0) { trim_      = v; }
    }

    int getLatencySamples() const { return (kTaps - 1) / 2; }

    void process(const float* in, float* out, int N) {
        if (!out) return;
        if (!in)  { for (int i = 0; i < N; ++i) out[i] = 0.0f; return; }

        const double trimLin = std::pow(10.0, trim_ / 20.0);

        for (int i = 0; i < N; ++i) {
            // 2× upsample (zero-stuff + halfband FIR, ×2 gain comp).
            const double x   = 2.0 * static_cast<double>(in[i]);
            const double up0 = pushAndConvolve(upBuf_, upIdx_, x);
            const double up1 = pushAndConvolve(upBuf_, upIdx_, 0.0);

            // Ladder runs at 2·Fs.
            const double y0 = ladderStep(up0);
            const double y1 = ladderStep(up1);

            // 2× downsample (halfband FIR + decimate).
            (void) pushAndConvolve(dnBuf_, dnIdx_, y0);   // discarded
            const double dn = pushAndConvolve(dnBuf_, dnIdx_, y1);

            out[i] = static_cast<float>(trimLin * dn);
        }
    }

private:
    static constexpr int kTaps = 63;

    // Modified Bessel I₀, series form (matches op_drive bit-for-bit).
    static double besselI0(double x) {
        double sum = 1.0, term = 1.0;
        const double q = x * x * 0.25;
        for (int k = 1; k < 50; ++k) {
            term *= q / static_cast<double>(k * k);
            sum  += term;
            if (term < 1.0e-20 * sum) break;
        }
        return sum;
    }

    void designHalfband() {
        constexpr double beta = 10.0;
        const double i0Beta = besselI0(beta);
        const int N    = kTaps - 1;
        const int half = kTaps / 2;
        for (int n = 0; n < kTaps; ++n) {
            const int m = n - half;
            double sinc;
            if (m == 0)            sinc = 0.5;
            else if ((m & 1) == 0) sinc = 0.0;
            else                   sinc = std::sin(0.5 * M_PI * m) / (M_PI * m);
            const double r = (2.0 * n - N) / static_cast<double>(N);
            const double a = beta * std::sqrt(1.0 - r * r);
            const double w = besselI0(a) / i0Beta;
            hb_[n] = sinc * w;
        }
    }

    double pushAndConvolve(std::array<double, kTaps>& buf, int& idx, double x) {
        buf[idx] = x;
        idx = (idx + 1) % kTaps;
        double y = 0.0;
        int j = idx;
        for (int t = 0; t < kTaps; ++t) {
            y += hb_[t] * buf[j];
            j = (j + 1) % kTaps;
        }
        return y;
    }

    void recomputeCoefs() {
        // Pre-warp at 2·Fs (the rate the ladder runs at inside the OS).
        const double sr2  = 2.0 * (sr_ > 0 ? sr_ : 48000.0);
        const double nyq2 = 0.5 * sr2 - 100.0;
        const double fc   = std::min(std::max(cutoff_, 20.0), nyq2);
        const double T2   = 1.0 / sr2;
        const double wd   = 2.0 * M_PI * fc;
        const double preArg = std::min(wd * T2 / 2.0, M_PI / 2.0 - 1e-4);
        const double t      = std::tan(preArg);
        G_ = t / (1.0 + t);
        const double res = std::min(std::max(resonance_, 0.0), 1.2);
        k_ = (4.0 / 1.2) * res;
    }

    // Single ladder sample at 2·Fs. Returns y4.
    double ladderStep(double x) {
        // Driver pair tanh on (drive·x − k·y4_prev). One-sample lag on FB.
        const double in_drv = drive_ * x - k_ * y4_prev_;
        const double th_drv = std::tanh(in_drv);

        // Stage 1
        const double v1 = (th_drv - s1_) * G_;
        y1_ = v1 + s1_;
        s1_ += 2.0 * v1;
        const double th_y1 = std::tanh(y1_);

        // Stage 2
        const double v2 = (th_y1 - s2_) * G_;
        y2_ = v2 + s2_;
        s2_ += 2.0 * v2;
        const double th_y2 = std::tanh(y2_);

        // Stage 3
        const double v3 = (th_y2 - s3_) * G_;
        y3_ = v3 + s3_;
        s3_ += 2.0 * v3;
        const double th_y3 = std::tanh(y3_);

        // Stage 4
        const double v4 = (th_y3 - s4_) * G_;
        y4_ = v4 + s4_;
        s4_ += 2.0 * v4;

        y4_prev_ = y4_;
        return y4_;
    }

    double sr_;
    double cutoff_    = 1000.0;
    double resonance_ = 0.0;
    double drive_     = 1.0;
    double trim_      = 0.0;

    double G_ = 0.0;
    double k_ = 0.0;

    double y1_ = 0.0, y2_ = 0.0, y3_ = 0.0, y4_ = 0.0;
    double s1_ = 0.0, s2_ = 0.0, s3_ = 0.0, s4_ = 0.0;
    double y4_prev_ = 0.0;

    std::array<double, kTaps> hb_{};
    std::array<double, kTaps> upBuf_{};
    std::array<double, kTaps> dnBuf_{};
    int upIdx_ = 0, dnIdx_ = 0;
};

}  // namespace shags::ops
