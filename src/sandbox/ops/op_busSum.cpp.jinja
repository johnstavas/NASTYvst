// op_busSum.cpp.jinja — Stage-3 native mirror of op_busSum.worklet.js.
//
// 4-input unity-gain summing bus. Math-by-definition: out = Σ inₖ.
// Catalog #26. Dual of #16 fanOut. Mirrors the worklet bit-for-bit.
#pragma once

namespace shags::ops {

class BusSumOp_{{ node_id }} {
public:
    static constexpr const char* opId = "busSum";

    explicit BusSumOp_{{ node_id }}(double sampleRate) : sr_(sampleRate) {}

    void reset() {}
    void setParam(const char*, double) {}
    int  getLatencySamples() const { return 0; }

    void process(const float* in0, const float* in1,
                 const float* in2, const float* in3,
                 float* out, int N) {
        if (!out) return;
        for (int i = 0; i < N; ++i) {
            float s = 0.0f;
            if (in0) s += in0[i];
            if (in1) s += in1[i];
            if (in2) s += in2[i];
            if (in3) s += in3[i];
            out[i] = s;
        }
    }

private:
    double sr_ = 0.0;
};

} // namespace shags::ops
