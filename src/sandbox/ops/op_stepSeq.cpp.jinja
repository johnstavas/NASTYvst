// op_stepSeq.cpp.jinja — C++ mirror of op_stepSeq.worklet.js.
// SC Stepper_next_a0 counter-advance + value-table lookup.

#pragma once
#include <cmath>
#include <algorithm>

struct OpStepSeq_{{ instance }} {
    float sr        = 48000.0f;
    int   p_length  = 8;
    float values[8] = {0,0,0,0,0,0,0,0};
    int   idx       = -1;
    float prevTrig  = 0.0f;
    float level     = 0.0f;

    void setSampleRate(float s) { sr = s; }
    void reset() { idx = -1; prevTrig = 0.0f; level = 0.0f; }

    void setParam_length(float v) {
        if (std::isfinite(v)) p_length = std::clamp((int)v, 1, 8);
    }
    void setStepValue(int k, float v) {
        if (k >= 0 && k < 8 && std::isfinite(v))
            values[k] = std::clamp(v, -1.0f, 1.0f);
    }
    // setParam_s0 .. setParam_s7
    void setParam_s0(float v){ setStepValue(0,v); }
    void setParam_s1(float v){ setStepValue(1,v); }
    void setParam_s2(float v){ setStepValue(2,v); }
    void setParam_s3(float v){ setStepValue(3,v); }
    void setParam_s4(float v){ setStepValue(4,v); }
    void setParam_s5(float v){ setStepValue(5,v); }
    void setParam_s6(float v){ setStepValue(6,v); }
    void setParam_s7(float v){ setStepValue(7,v); }

    void process(const float* trig, float* out, int N) {
        if (!out) return;
        for (int n = 0; n < N; ++n) {
            const float t = trig ? trig[n] : 0.0f;
            if (prevTrig <= 0.0f && t > 0.0f) {
                idx = (idx + 1) % p_length;
                if (idx < 0) idx += p_length;
                level = values[idx];
            }
            out[n] = level;
            prevTrig = t;
        }
    }

    int getLatencySamples() const { return 0; }
};
