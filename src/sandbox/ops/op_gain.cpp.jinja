#pragma once
#include <cmath>
#include <cstring>

namespace shags::ops {

class GainOp_{{ node_id }} {
public:
    static constexpr const char* opId = "gain";

    GainOp_{{ node_id }}() = default;
    explicit GainOp_{{ node_id }}(double sampleRate) : sr_(sampleRate) {}

    void reset() { baseSmoothed_ = -1.0; /* triggers prime-on-first-block */ }

    void setParam(const char* id, double v) {
        if (std::strcmp(id, "gainDb") == 0) gainDb_ = v;
    }

    int getLatencySamples() const { return 0; }

    // in:      mono audio input  (nullptr if unwired -> output silence)
    // gainMod: mono control input (nullptr if unwired -> static gain)
    // out:     mono audio output
    //
    // PER-SAMPLE PARAM SMOOTHING (added 2026-04-27 to kill knob-twiddle clicks):
    //   base linearly ramps from baseSmoothed_ to baseTarget over N samples.
    //   This eliminates the single-block step that produced audible clicks
    //   when the user moved In/Out/VCA gains or clicked preset buttons that
    //   set new param values instantly via APVTS::setValueNotifyingHost.
    //
    // Mirrors op_gain.worklet.js (which now also smooths).
    void process(const float* in, const float* gainMod, float* out, int N) {
        const double baseTarget = std::pow(10.0, gainDb_ / 20.0);
        if (baseSmoothed_ < 0.0) baseSmoothed_ = baseTarget;     // prime on first block
        const double increment = (baseTarget - baseSmoothed_) / static_cast<double>(N > 0 ? N : 1);
        if (in == nullptr) {
            for (int i = 0; i < N; ++i) out[i] = 0.0f;
            baseSmoothed_ = baseTarget;
            return;
        }
        double b = baseSmoothed_;
        if (gainMod != nullptr) {
            for (int i = 0; i < N; ++i) {
                b += increment;
                out[i] = static_cast<float>(in[i] * (b + gainMod[i]));
            }
        } else {
            for (int i = 0; i < N; ++i) {
                b += increment;
                out[i] = static_cast<float>(in[i] * b);
            }
        }
        baseSmoothed_ = baseTarget;   // snap to target to avoid float drift
    }

private:
    double sr_ = 44100.0;
    double gainDb_ = 0.0;
    double baseSmoothed_ = -1.0;   // <0 sentinel = "prime on first block"
};

