// op_slew.cpp — Stage-3b C++ sidecar for the `slew` op.
// Contract: memory/codegen_design.md § 4. Mirrors op_slew.worklet.js math
// bit-for-bit (linear-rate slew limiter, asymmetric rise/fall).
// Template language: Jinja2. {{ graph_id }} / {{ node_id }} injected by emitter.
// Regenerated from this file + PCOF at build time — DO NOT hand-edit emitted .cpp.
//
//   step_up    = 1 / (riseMs * sr / 1000)
//   step_down  = 1 / (fallMs * sr / 1000)
//
//   delta = x[n] - y[n-1]
//   if   delta >  step_up  : y[n] = y[n-1] + step_up
//   elif delta < -step_down: y[n] = y[n-1] - step_down
//   else                   : y[n] = x[n]
//
// Float64 state, Jon Watte denormal flush (Canon:utilities §1).
// Zero latency — causal, sample-by-sample.
#pragma once
#include <cmath>
#include <cstring>

namespace shags::ops {

class SlewOp_{{ node_id }} {
public:
    static constexpr const char* opId = "slew";

    explicit SlewOp_{{ node_id }}(double sampleRate) : sr_(sampleRate) {
        recomputeSteps();
    }

    void reset() { y_ = 0.0; }

    void setParam(const char* id, double v) {
        if (!std::isfinite(v)) return;
        const double clamped = v < 0.001 ? 0.001 : (v > 10000.0 ? 10000.0 : v);
        if (std::strcmp(id, "riseMs") == 0) {
            riseMs_ = clamped;
            recomputeSteps();
        } else if (std::strcmp(id, "fallMs") == 0) {
            fallMs_ = clamped;
            recomputeSteps();
        }
    }

    int getLatencySamples() const { return 0; }

    // in:  mono input (nullptr → glide toward 0 at fall rate)
    // out: mono output
    void process(const float* in, float* out, int N) {
        if (!out) return;
        const double up   = stepUp_;
        const double down = stepDown_;
        double y = y_;

        if (!in) {
            for (int i = 0; i < N; ++i) {
                const double delta = -y;
                if (delta > up)         y += up;
                else if (delta < -down) y -= down;
                else                    y = 0.0;
                if (y < kDenormal_ && y > -kDenormal_) y = 0.0;
                out[i] = static_cast<float>(y);
            }
        } else {
            for (int i = 0; i < N; ++i) {
                const double target = static_cast<double>(in[i]);
                const double delta  = target - y;
                if (delta > up)         y += up;
                else if (delta < -down) y -= down;
                else                    y = target;
                if (y < kDenormal_ && y > -kDenormal_) y = 0.0;
                out[i] = static_cast<float>(y);
            }
        }

        y_ = y;
    }

private:
    void recomputeSteps() {
        stepUp_   = 1.0 / (riseMs_ * sr_ * 0.001);
        stepDown_ = 1.0 / (fallMs_ * sr_ * 0.001);
    }

    static constexpr double kDenormal_ = 1e-30;

    double sr_;
    double riseMs_   = 10.0;
    double fallMs_   = 50.0;
    double stepUp_   = 0.0;
    double stepDown_ = 0.0;
    double y_        = 0.0;
};

}  // namespace shags::ops
