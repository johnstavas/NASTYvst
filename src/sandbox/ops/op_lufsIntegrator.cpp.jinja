// Catalog #52, Canon:loudness §3 (BS.1770-5 / EBU Tech 3341 V4).
//
// EBU-MODE COMPLIANT sliding rectangular window.
// Template: Jinja2.
#pragma once
#include <cstring>
#include <cmath>
#include <algorithm>
#include <vector>

namespace shags::ops {

class LufsIntegratorOp_{{ node_id }} {
public:
    static constexpr const char* opId = "lufsIntegrator";
    static constexpr int MAX_BUF = 576000 + 8;  // 3 s @ 192 kHz headroom

    explicit LufsIntegratorOp_{{ node_id }}(double sampleRate) : sr_(sampleRate) {
        buf_.assign(MAX_BUF, 0.0f);
        applyMode();
    }

    void reset() { flush(); }

    void setParam(const char* id, double v) {
        if (std::strcmp(id, "channelWeight") == 0) {
            if (!std::isfinite(v)) return;
            G_ = std::min(std::max(v, 0.0), 2.0);
        }
    }

    void setMode(const char* m) {
        const bool next = (std::strcmp(m, "short-term") == 0);
        if (next != modeShort_) {
            modeShort_ = next;
            applyMode();
        }
    }

    int getLatencySamples() const { return 0; }

    void process(const float* in, float* out, int N) {
        if (!out) return;
        constexpr double LUFS_OFFSET = -0.691;
        constexpr double MS_FLOOR    = 1e-12;
        const int    winLen = winLen_;
        const double G      = G_;
        int    idx    = idx_;
        int    filled = filled_;
        double sumSq  = sumSq_;

        for (int i = 0; i < N; ++i) {
            const double x   = in ? static_cast<double>(in[i]) : 0.0;
            const double xsq = x * x;
            const double leaving = static_cast<double>(buf_[idx]);
            sumSq += xsq - leaving;
            buf_[idx] = static_cast<float>(xsq);

            if (++idx >= winLen) idx = 0;
            if (filled < winLen) ++filled;

            double s = sumSq;
            if (s < 0.0) s = 0.0;
            const int effN = filled > 0 ? filled : 1;
            double ms = G * s / static_cast<double>(effN);
            if (ms < MS_FLOOR) ms = MS_FLOOR;
            out[i] = static_cast<float>(LUFS_OFFSET + 10.0 * std::log10(ms));
        }

        idx_    = idx;
        filled_ = filled;
        sumSq_  = sumSq;
    }

private:
    void applyMode() {
        const double sec = modeShort_ ? 3.0 : 0.4;
        int N = static_cast<int>(std::round(sec * sr_));
        if (N < 1)       N = 1;
        if (N > MAX_BUF) N = MAX_BUF;
        winLen_ = N;
        flush();
    }

    void flush() {
        std::fill(buf_.begin(), buf_.begin() + winLen_, 0.0f);
        idx_    = 0;
        filled_ = 0;
        sumSq_  = 0.0;
    }

    double sr_;
    bool   modeShort_ = false;
    double G_         = 1.0;
    std::vector<float> buf_;
    int    winLen_ = 0;
    int    idx_    = 0;
    int    filled_ = 0;
    double sumSq_  = 0.0;
};

}  // namespace shags::ops
