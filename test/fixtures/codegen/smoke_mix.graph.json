{
  "schemaVersion": "1.0",
  "id": "smoke-mix-v0",
  "label": "SmokeMix",
  "canvas": { "width": 600, "height": 240 },
  "terminals": [
    { "id": "in",  "kind": "input",  "x":  40, "y": 120 },
    { "id": "out", "kind": "output", "x": 560, "y": 120 }
  ],
  "nodes": [
    { "id": "n_const", "op": "constant", "x": 200, "y":  60, "params": { "value": 0.5 } },
    { "id": "n_mix",   "op": "mix",      "x": 380, "y": 120, "params": { "amount": 0.3 } }
  ],
  "wires": [
    { "from": "in",          "to": "n_mix.dry" },
    { "from": "n_const.out", "to": "n_mix.wet" },
    { "from": "n_mix.out",   "to": "out" }
  ],
  "feedback": [],
  "legendOps": ["constant", "mix"]
}
